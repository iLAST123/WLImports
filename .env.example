# Credenciais da API do Bling (v3, OAuth 2.0) — usadas SOMENTE no servidor.
# Copie este arquivo para `.env.local` e preencha. `.env.local` está no
# .gitignore e NUNCA deve ser commitado.
#
# Enquanto CLIENT_ID/SECRET/REFRESH_TOKEN estiverem vazios, o site usa o
# catálogo MOCK automaticamente (zero configuração).

# Cadastro do aplicativo em https://developer.bling.com.br (aba "Aplicativos").
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=

# Refresh token SEMENTE, obtido UMA única vez pelo fluxo OAuth authorization
# code (troca do `code` da autorização por tokens). O access_token NÃO vai em
# env — expira em ~6h e é renovado automaticamente.
#
# A partir da primeira renovação, o refresh token ROTACIONA e é persistido em
# `.bling-tokens.json` (na raiz, no .gitignore). Esse arquivo tem PRECEDÊNCIA
# sobre a semente abaixo. Só reautorize (gerando nova semente) se o fluxo
# quebrar por perda desse arquivo.
BLING_REFRESH_TOKEN=

# (Opcional) Caminho alternativo para o arquivo de tokens persistido.
# BLING_TOKEN_STORE_PATH=
