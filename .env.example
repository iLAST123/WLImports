# Credenciais da API do Bling (v3, OAuth 2.0) — usadas SOMENTE no servidor (API Routes).
# Copie este arquivo para `.env.local` e preencha com as credenciais reais.
# `.env.local` está no .gitignore e NUNCA deve ser commitado.

# Obtidas ao cadastrar o aplicativo em https://developer.bling.com.br
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=

# Access token gerado pelo fluxo OAuth 2.0 (authorization code).
# Enquanto estiver vazio, o site usa o catálogo MOCK automaticamente.
BLING_ACCESS_TOKEN=
